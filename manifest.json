{
  "id": "/control-panel-logs/",
  "name": "Monitor Inventario Pro",
  "short_name": "Monitor",
  "description": "Panel de Control y Monitoreo en Tiempo Real",
  "lang": "es",
  "dir": "ltr",
  "start_url": "./index.html",
  "scope": "/control-panel-logs/",
  "display": "standalone",
  "display_override": ["tabbed", "window-controls-overlay", "standalone"],
  "orientation": "portrait",
  "background_color": "#f4f7f6",
  "theme_color": "#34495e",
  "categories": ["productivity", "utilities"],
  "iarc_rating_id": "e58c174a-81d2-5c3c-32cc-34b8de4a52e9",
  "icons": [
    {
      "src": "./icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "./icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    },
    {
      "src": "./maskable-icon.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "./logo.svg",
      "sizes": "any",
      "type": "image/svg+xml"
    }
  ],
  "screenshots": [
    {
      "src": "https://placehold.co/1280x720/34495e/FFFFFF.png?text=Dashboard+Desktop",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide"
    },
    {
      "src": "https://placehold.co/720x1280/34495e/FFFFFF.png?text=Dashboard+Mobile",
      "sizes": "720x1280",
      "type": "image/png",
      "form_factor": "narrow"
    }
  ],
  "shortcuts": [
    {
      "name": "Enviar Ping",
      "short_name": "Ping",
      "description": "Enviar un ping de prueba al servidor",
      "url": "./index.html?action=ping",
      "icons": [{ "src": "./icon-192.png", "sizes": "192x192" }]
    }
  ],
  "prefer_related_applications": true,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.netizen.monitorinventario",
      "id": "com.netizen.monitorinventario"
    }
  ],
  "note_taking": {
    "new_note_url": "./index.html?action=new_note"
  },
  "widgets": [
    {
      "name": "Monitor Widget",
      "description": "Muestra el estado de conexión del monitor",
      "tag": "monitor-status",
      "template_url": "./index.html?widget=true",
      "ms_ac_template": "./index.html?widget=true",
      "auth_base_url": "./index.html",
      "backgrounds": ["#f4f7f6"]
    }
  ],
  "share_target": {
    "action": "./index.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "text/plain": [".log", ".txt"],
        "application/json": [".json"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+monitor",
      "url": "./index.html?link=%s"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "scope_extensions": [
    {
      "origin": "*.github.io"
    }
  ]
}